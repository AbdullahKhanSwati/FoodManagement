{
  "expo": {
    "name": "Easy Eats",
    "slug": "food-support",
    "version": "1.0.0",
    "orientation": "portrait",
    "splash": {
      "image": "./assets/splash.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#F7FBF8"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.calmingcompass.easyeats"
    },
    "android": {
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.jpeg",
        "backgroundColor": "#F7FBF8"
      },
      "package": "com.calmingcompass.easyeats",
      "versionCode": 1
    },
    "web": {},
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.jpeg",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F7FBF8"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c8b75e3d-2a24-4ac8-b950-402482e650da"
      }
    },
    "owner": "abdullahg144"
  }
}
